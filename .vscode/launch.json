{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Verify all (1.1 -> 2.x unblocker)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/verify_all.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/venv/Scripts/python.exe"
    },
    {
      "name": "Make sample data",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/make_sample_data.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/venv/Scripts/python.exe"
    },
    {
      "name": "Run pipeline (live Optimeering)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_pipeline.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/venv/Scripts/python.exe"
    }
  ]
}
