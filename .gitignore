.env
venv/
.venv/
__pycache__/

# Python build / packaging artifacts
*.egg-info/
build/
dist/
.pytest_cache/

# Local data artifacts (keep the folders via .gitkeep, ignore contents)
data/iar.db
data/iar.db-wal
data/iar.db-shm
data/refresh.lock
data/refresh.log
data/limits_override.json
data/cache/*
data/uploads/*
!data/cache/.gitkeep
!data/uploads/.gitkeep

# Local-only tooling config and scratch files
.claude/settings.local.json
test_apkey.py
CLAUDE.md

# Scratch (throwaway) — never committed
scratch/

# Vendored internal SDK wheel (optipyclient) — pulled from Volue/sirius-prime releases
vendor/
# uv lockfile intentionally not committed for the demo: Streamlit Cloud runs an older
# uv that cannot parse a newer-uv lock ("missing field version"); committing it also diverts
# Cloud from the known-good pip install -r requirements.txt path. CI uses uv sync (no --frozen).
uv.lock
